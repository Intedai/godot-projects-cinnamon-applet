{
    "head": {
        "type": "header",
        "description": "Godot Projects Applet Settings"    
    },
    "use-monochrome-icon": {
        "type": "switch",
        "default": true,
        "description": "Use a monochrome icon"
    },
    "monochrome-icon-color": {
        "type": "colorchooser",
        "default": "white",
        "dependency": "use-monochrome-icon=true",
        "description": "Choose a color for the icon"
    },
    "show-full-path": {
        "type": "switch",
        "default": false,
        "description": "Show Full Path Instead Of Project Name"
    },
    "show-star-icons": {
        "type": "switch",
        "default": true,
        "description": "Show Star Icons Near Project"
    },
    "godot-command": {
        "type": "entry",
        "default": "godot",
        "description": "Godot Command",
        "tooltip": "For example: godot, flatpak run org.godotengine.Godot or ./{EXECUTABLE PATH}"
    },
    "godot-flags": {
        "type": "entry",
        "default": "--editor --path",
        "description": "Godot flags"
    },
    "custom-projects-path": {
        "type": "switch",
        "default": false,
        "description": "Use a custom path for projects.cfg",
        "tooltip": "Usually for a Flatpak"
    },
    "projects-file-uri": {
        "type": "filechooser",
        "default": "",
        "dependency": "custom-projects-path=true",
        "description": "Choose your projects.cfg file",
        "tooltip": "~/.local/share/godot/project.cfg or for flatpak ~/.var/app/org.godotengine.Godot/data/godot usually"
    }
}
